# ==============================================================================
# SELEÇÃO FESF-SUS - CONFIGURAÇÃO GLOBAL DE SESSÃO E INFRAESTRUTURA
# ==============================================================================


.vev
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# Ambientes Virtuais e Gerenciadores de Dependência
.venv/
backend/venv/
ENV/
env/
.pdm-plugins/
.pdm-build/

# Cache do Python e Compilações Internas
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest_cache
.mypy_cache/
.ruff_cache/

# Banco de Dados Local do MVP (SQLite)
# (Evita que os seus testes locais poluam o histórico do Git)
*.db
*.sqlite3
backend/src/*.db
backend/src/*.sqlite3

# ------------------------------------------------------------------------------
# ⚛️ FRONTEND (Node.js / React / Next.js)
# ------------------------------------------------------------------------------

# Dependências Locais do NPM / Yarn
node_modules/
/node_modules
**/node_modules/

# Pastas de Compilação e Artefatos do Next.js
.next/
/out/
build/
dist/

# Logs de Erros e Diagnósticos do Sistema
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Arquivos de Telemetria Locais do Next.js
.next/cache/

# ------------------------------------------------------------------------------
# 🐳 INFRAESTRUTURA (Docker / IDEs / SO)
# ------------------------------------------------------------------------------

# Arquivos temporários de IDEs (VS Code, PyCharm)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.yml


# Arquivos ocultos do Sistema Operacional
.DS_Store
Thumbs.db

